<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Kyle Tuck</title>
  <link rel="icon" href="pipe.png" type="image/png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Share+Tech+Mono&display=swap" rel="stylesheet" />

  <style>
    :root {
      --bg: #070812;
      --bg-2: #11152a;
      --screen: rgba(9, 18, 30, 0.88);
      --screen-soft: rgba(14, 31, 47, 0.72);
      --cyan: #00f5ff;
      --cyan-soft: rgba(0, 245, 255, 0.25);
      --lime: #a8ff60;
      --amber: #ffd166;
      --pink: #ff2fd6;
      --red: #ff3131;
      --text: #d8fff7;
      --muted: #8db9b8;
      --shadow-cyan: 0 0 8px rgba(0, 245, 255, 0.8), 0 0 24px rgba(0, 245, 255, 0.28);
      --shadow-pink: 0 0 8px rgba(255, 47, 214, 0.8), 0 0 24px rgba(255, 47, 214, 0.28);
      --scanline: rgba(255, 255, 255, 0.045);
      --pixel: 4px;
    }

    * { box-sizing: border-box; }

    html, body { height: 100%; }

    body {
      margin: 0;
      min-height: 100vh;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
      color: var(--text);
      font-family: 'Share Tech Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
      background:
        radial-gradient(circle at 20% 20%, rgba(255, 47, 214, 0.2), transparent 34%),
        radial-gradient(circle at 82% 18%, rgba(0, 245, 255, 0.2), transparent 32%),
        radial-gradient(circle at 50% 80%, rgba(168, 255, 96, 0.11), transparent 38%),
        linear-gradient(135deg, var(--bg), var(--bg-2) 58%, #090714);
      position: relative;
    }

    body::before,
    body::after {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 50;
    }

    body::before {
      background:
        repeating-linear-gradient(
          to bottom,
          rgba(255, 255, 255, 0.055) 0,
          rgba(255, 255, 255, 0.055) 1px,
          transparent 1px,
          transparent 4px
        );
      mix-blend-mode: overlay;
      opacity: 0.55;
      animation: scanMove 7s linear infinite;
    }

    body::after {
      background:
        linear-gradient(rgba(255, 255, 255, 0.025), transparent 9%, transparent 91%, rgba(0, 0, 0, 0.34)),
        radial-gradient(circle at 50% 50%, transparent 0 58%, rgba(0, 0, 0, 0.48) 100%);
    }

    @keyframes scanMove {
      from { transform: translateY(0); }
      to { transform: translateY(16px); }
    }

    .retro-grid {
      position: fixed;
      inset: auto -10vw -26vh -10vw;
      height: 48vh;
      transform: perspective(680px) rotateX(62deg);
      transform-origin: bottom center;
      background-image:
        linear-gradient(rgba(0, 245, 255, 0.2) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 47, 214, 0.18) 1px, transparent 1px);
      background-size: 48px 48px;
      filter: drop-shadow(0 0 12px rgba(0, 245, 255, 0.28));
      opacity: 0.62;
      animation: gridDrive 9s linear infinite;
      z-index: 0;
    }

    @keyframes gridDrive {
      from { background-position: 0 0, 0 0; }
      to { background-position: 0 96px, 96px 0; }
    }

    .orb {
      position: fixed;
      width: min(42vw, 520px);
      aspect-ratio: 1;
      top: 8vh;
      left: 50%;
      transform: translateX(-50%);
      border-radius: 50%;
      background:
        repeating-linear-gradient(
          to bottom,
          rgba(255, 209, 102, 0.9) 0 8px,
          rgba(255, 112, 166, 0.78) 8px 18px,
          transparent 18px 30px
        );
      box-shadow: 0 0 40px rgba(255, 47, 214, 0.28), 0 0 90px rgba(255, 209, 102, 0.18);
      opacity: 0.22;
      filter: blur(0.2px);
      z-index: 0;
    }

    body.is-navigating .container,
    body.is-navigating .search-bar,
    body.is-navigating footer,
    body.is-navigating .retro-grid,
    body.is-navigating .orb {
      opacity: 0 !important;
    }

    #loader {
      position: fixed;
      inset: 0;
      display: grid;
      place-items: center;
      z-index: 9999;
      background: rgba(5, 8, 18, 0.76);
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transition: opacity 0.25s ease, visibility 0.25s ease;
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
    }

    #loader.active {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
    }

    .boot-box {
      width: min(86vw, 460px);
      border: 2px solid var(--cyan);
      background: rgba(4, 14, 22, 0.92);
      box-shadow: var(--shadow-cyan), inset 0 0 28px rgba(0, 245, 255, 0.12);
      padding: 22px;
      text-align: left;
      position: relative;
    }

    .boot-box::before {
      content: "SYSTEM LOADER";
      position: absolute;
      top: -12px;
      left: 14px;
      padding: 0 8px;
      background: #07101b;
      color: var(--amber);
      font-family: 'Press Start 2P', monospace;
      font-size: 10px;
      letter-spacing: 1px;
    }

    .boot-line {
      font-size: 18px;
      color: var(--lime);
      text-shadow: 0 0 10px rgba(168, 255, 96, 0.55);
      margin-bottom: 18px;
      white-space: nowrap;
      overflow: hidden;
    }

    .boot-line::after {
      content: "_";
      animation: blink 0.8s steps(1) infinite;
    }

    .progress {
      height: 18px;
      border: 1px solid rgba(0, 245, 255, 0.8);
      padding: 3px;
      background: rgba(0, 0, 0, 0.42);
    }

    .progress span {
      display: block;
      height: 100%;
      width: 38%;
      background: linear-gradient(90deg, var(--pink), var(--cyan), var(--lime));
      box-shadow: 0 0 18px rgba(0, 245, 255, 0.6);
      animation: progressPulse 0.85s steps(7) infinite alternate;
    }

    @keyframes progressPulse {
      from { width: 14%; }
      to { width: 100%; }
    }

    @keyframes blink {
      0%, 49% { opacity: 1; }
      50%, 100% { opacity: 0; }
    }

    .search-bar {
      position: fixed;
      top: 20px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 60;
      width: min(92vw, 370px);
      transition: opacity 0.15s ease;
    }

    .search-shell {
      position: relative;
    }

    .search-shell::before {
      content: ">";
      position: absolute;
      top: 50%;
      left: 14px;
      transform: translateY(-50%);
      color: var(--lime);
      text-shadow: 0 0 10px rgba(168, 255, 96, 0.7);
      z-index: 2;
    }

    #searchInput {
      width: 100%;
      padding: 13px 14px 13px 35px;
      border: 2px solid rgba(0, 245, 255, 0.86);
      border-radius: 0;
      outline: none;
      color: var(--text);
      background: rgba(4, 14, 22, 0.84);
      box-shadow: var(--shadow-cyan), inset 0 0 20px rgba(0, 245, 255, 0.08);
      font-family: 'Share Tech Mono', monospace;
      font-size: 17px;
      letter-spacing: 0.04em;
      caret-color: var(--lime);
      text-transform: uppercase;
    }

    #searchInput::placeholder {
      color: rgba(216, 255, 247, 0.45);
      text-transform: none;
    }

    #searchInput:focus {
      border-color: var(--pink);
      box-shadow: var(--shadow-pink), inset 0 0 22px rgba(255, 47, 214, 0.08);
    }

    .suggestions {
      position: absolute;
      top: calc(100% + 8px);
      left: 0;
      width: 100%;
      max-height: 190px;
      overflow-y: auto;
      border: 2px solid rgba(255, 47, 214, 0.75);
      background: rgba(6, 11, 24, 0.96);
      box-shadow: var(--shadow-pink);
      display: none;
      z-index: 80;
    }

    .suggestion {
      padding: 11px 14px;
      cursor: pointer;
      color: var(--text);
      border-bottom: 1px solid rgba(0, 245, 255, 0.18);
      letter-spacing: 0.04em;
      transition: background 0.15s ease, color 0.15s ease, transform 0.15s ease;
    }

    .suggestion:last-child { border-bottom: 0; }

    .suggestion:hover,
    .suggestion.selected {
      background: linear-gradient(90deg, rgba(255, 47, 214, 0.24), rgba(0, 245, 255, 0.13));
      color: var(--lime);
      transform: translateX(4px);
    }

    .container {
      width: min(92vw, 680px);
      position: relative;
      z-index: 10;
      padding: clamp(26px, 6vw, 46px);
      text-align: center;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.01)),
        var(--screen);
      border: 2px solid var(--cyan);
      box-shadow:
        var(--shadow-cyan),
        inset 0 0 32px rgba(0, 245, 255, 0.09),
        12px 12px 0 rgba(255, 47, 214, 0.25);
      transition: opacity 0.15s ease;
      animation: powerOn 0.85s cubic-bezier(.19,1,.22,1) both;
    }

    .container::before {
      content: "KYLE_OS // MAIN MENU";
      position: absolute;
      top: -15px;
      left: 18px;
      padding: 0 10px;
      background: #08101c;
      color: var(--amber);
      font-family: 'Press Start 2P', monospace;
      font-size: clamp(9px, 1.9vw, 12px);
      letter-spacing: 1px;
    }

    .container::after {
      content: "";
      position: absolute;
      inset: 10px;
      border: 1px dashed rgba(168, 255, 96, 0.25);
      pointer-events: none;
    }

    @keyframes powerOn {
      0% { opacity: 0; transform: scaleY(0.02) translateY(12px); filter: brightness(3); }
      45% { opacity: 1; transform: scaleY(1.06) translateY(0); filter: brightness(1.4); }
      100% { opacity: 1; transform: scaleY(1) translateY(0); filter: brightness(1); }
    }

    .eyebrow {
      margin: 0 0 16px;
      color: var(--lime);
      font-size: 16px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      text-shadow: 0 0 10px rgba(168, 255, 96, 0.52);
    }

    h1 {
      margin: 0 0 18px;
      color: var(--cyan);
      font-family: 'Press Start 2P', monospace;
      font-size: clamp(2rem, 8vw, 4.2rem);
      line-height: 1.18;
      letter-spacing: 0.05em;
      text-shadow:
        3px 0 0 rgba(255, 47, 214, 0.75),
        -3px 0 0 rgba(168, 255, 96, 0.55),
        0 0 18px rgba(0, 245, 255, 0.58);
      animation: microGlitch 4.8s infinite steps(1);
    }

    @keyframes microGlitch {
      0%, 90%, 100% { transform: translate(0); }
      91% { transform: translate(-2px, 1px); }
      92% { transform: translate(2px, -1px); }
      93% { transform: translate(-1px, -1px); }
      94% { transform: translate(0); }
    }

    .lead {
      width: min(100%, 520px);
      margin: 0 auto 30px;
      color: var(--muted);
      font-size: clamp(17px, 3.4vw, 21px);
      line-height: 1.45;
    }

    .tool-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 16px;
      margin: 0 auto;
      width: min(100%, 500px);
    }

    @media (min-width: 560px) {
      .tool-grid { grid-template-columns: 1fr 1fr; }
    }

    .button {
      appearance: none;
      border: 2px solid var(--cyan);
      border-radius: 0;
      color: var(--text);
      cursor: pointer;
      background:
        linear-gradient(180deg, rgba(0, 245, 255, 0.13), rgba(255, 47, 214, 0.08)),
        rgba(2, 7, 17, 0.86);
      padding: 18px 16px;
      min-height: 64px;
      position: relative;
      overflow: hidden;
      font-family: 'Press Start 2P', monospace;
      font-size: clamp(10px, 2.6vw, 13px);
      line-height: 1.5;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      box-shadow: 6px 6px 0 rgba(0, 245, 255, 0.18);
      transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease, color 0.15s ease;
    }

    .button::before {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.22), transparent);
      transform: translateX(-115%);
      transition: transform 0.45s ease;
    }

    .button::after {
      content: attr(data-hotkey);
      position: absolute;
      top: 5px;
      right: 7px;
      color: rgba(255, 209, 102, 0.8);
      font-family: 'Share Tech Mono', monospace;
      font-size: 12px;
      letter-spacing: 0.08em;
    }

    .button:hover,
    .button:focus-visible {
      transform: translate(-3px, -3px);
      border-color: var(--pink);
      color: var(--lime);
      box-shadow: 9px 9px 0 rgba(255, 47, 214, 0.28), 0 0 20px rgba(255, 47, 214, 0.25);
      outline: none;
    }

    .button:hover::before,
    .button:focus-visible::before {
      transform: translateX(115%);
    }

    .status-strip {
      margin: 28px auto 0;
      display: flex;
      justify-content: space-between;
      gap: 10px;
      width: min(100%, 520px);
      color: rgba(216, 255, 247, 0.62);
      font-size: 14px;
      border-top: 1px solid rgba(0, 245, 255, 0.24);
      padding-top: 14px;
      text-align: left;
    }

    .status-strip span:last-child { color: var(--amber); }

    footer {
      position: fixed;
      right: 16px;
      bottom: 12px;
      z-index: 60;
      color: rgba(216, 255, 247, 0.56);
      font-size: 13px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      transition: opacity 0.15s ease;
    }

    #glitchOverlay {
      position: fixed;
      inset: 0;
      z-index: 10000;
      background: #000;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      overflow: hidden;
    }

    #glitchOverlay.active {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
    }

    #glitchOverlay::before,
    #glitchOverlay::after {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      z-index: 2;
    }

    #glitchOverlay::before {
      background:
        repeating-linear-gradient(to bottom, rgba(255, 255, 255, 0.12) 0 1px, transparent 1px 5px),
        repeating-linear-gradient(90deg, rgba(255, 0, 0, 0.12) 0 3px, rgba(0, 255, 255, 0.08) 3px 6px, transparent 6px 12px);
      mix-blend-mode: screen;
      animation: staticShift 0.11s infinite steps(2);
    }

    #glitchOverlay::after {
      background: radial-gradient(circle, transparent 0 44%, rgba(0, 0, 0, 0.64) 100%);
    }

    @keyframes staticShift {
      0% { transform: translate(0, 0); opacity: 0.6; }
      50% { transform: translate(-12px, 7px); opacity: 0.9; }
      100% { transform: translate(9px, -6px); opacity: 0.7; }
    }

    #glitchVideo {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0.88;
      filter: contrast(1.4) saturate(1.4);
    }

    #errorText {
      position: relative;
      z-index: 3;
      color: var(--red);
      font-family: 'Press Start 2P', monospace;
      font-size: clamp(42px, 13vw, 152px);
      letter-spacing: 0.16em;
      text-transform: uppercase;
      text-shadow:
        4px 0 0 rgba(0, 245, 255, 0.8),
        -4px 0 0 rgba(255, 47, 214, 0.8),
        0 0 18px rgba(255, 49, 49, 0.8),
        0 0 42px rgba(255, 49, 49, 0.45);
      user-select: none;
      pointer-events: none;
      animation: errorGlitch 0.13s infinite steps(2);
    }

    @keyframes errorGlitch {
      0% { transform: translate(0, 0) skewX(0); opacity: 1; }
      25% { transform: translate(-7px, 4px) skewX(5deg); opacity: 0.82; }
      50% { transform: translate(5px, -5px) skewX(-4deg); opacity: 1; }
      75% { transform: translate(-4px, 3px) skewX(3deg); opacity: 0.9; }
      100% { transform: translate(0, 0) skewX(0); opacity: 1; }
    }

    @media (max-width: 420px) {
      body { padding: 18px; }
      .container { box-shadow: var(--shadow-cyan), 7px 7px 0 rgba(255, 47, 214, 0.22); }
      .status-strip { flex-direction: column; align-items: flex-start; }
      footer { left: 14px; right: auto; }
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.001ms !important;
        animation-iteration-count: 1 !important;
        scroll-behavior: auto !important;
        transition-duration: 0.001ms !important;
      }
    }
  </style>
</head>

<body>
  <div class="orb" aria-hidden="true"></div>
  <div class="retro-grid" aria-hidden="true"></div>

  <div id="loader" aria-hidden="true">
    <div class="boot-box" role="status" aria-live="polite">
      <div class="boot-line">Loading selected module</div>
      <div class="progress"><span></span></div>
    </div>
  </div>

  <div class="search-bar">
    <div class="search-shell">
      <input type="text" placeholder="Search page..." id="searchInput" autocomplete="off" spellcheck="false" />
      <div id="suggestions" class="suggestions"></div>
    </div>
  </div>

  <main class="container" aria-label="Kyle Tuck tool menu">
    <p class="eyebrow">Boot sequence complete</p>
    <h1 id="animatedTitle">Welcome</h1>
    <p class="lead">Select a module below, or type a command into the neon terminal search.</p>

    <div class="tool-grid">
      <button class="button" data-hotkey="01" onclick="loadPage('pipes')">Pipe Formatter</button>
      <button class="button" data-hotkey="02" onclick="loadPage('date')">Date Checker</button>
    </div>

    <div class="status-strip" aria-hidden="true">
      <span>READY // ONLINE</span>
      <span id="clockText">00:00:00</span>
    </div>
  </main>

  <footer>Kyle Tuck Inc.</footer>

  <div id="glitchOverlay" aria-hidden="true">
    <video id="glitchVideo" src="glitch.mp4" preload="auto" playsinline muted></video>
    <div id="errorText">ERROR</div>
  </div>

  <script>
    const loader = document.getElementById('loader');
    const searchInputEl = document.getElementById('searchInput');
    const suggestionsBox = document.getElementById('suggestions');
    const glitchOverlay = document.getElementById('glitchOverlay');
    const glitchVideo = document.getElementById('glitchVideo');
    const clockText = document.getElementById('clockText');

    const GLITCH_NAV_MS = 1500;
    let navigating = false;
    let currentSelection = -1;
    let currentMatches = [];

    function showLoader() {
      loader.classList.add('active');
      loader.setAttribute('aria-hidden', 'false');
    }

    function hideLoader() {
      loader.classList.remove('active');
      loader.setAttribute('aria-hidden', 'true');
    }

    function dismissMobileKeyboard() {
      try { searchInputEl?.blur(); } catch (e) {}
    }

    function normalize(str) {
      return (str || '')
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, ' ')
        .trim();
    }

    const pages = [
      { name: 'Pipe Formatter', path: 'pipes', hidden: false, aliases: ['pipe', 'formatter', 'pipes'] },
      { name: 'Date Checker', path: 'date', hidden: false, aliases: ['date', 'checker'] },
      { name: 'Kyle', path: 'personal', hidden: true, aliases: ['personal', 'jeff123199', 'admin', 'kyle'] }
    ];

    pages.forEach((page, index) => {
      const testAlias = `test${index + 1}`;
      page.aliases = page.aliases ? [...page.aliases, testAlias] : [testAlias];
    });

    const pageIndex = pages.map(page => {
      const searchableText = [page.name, page.path, ...(page.aliases || [])].join(' ');
      const tokens = normalize(searchableText).split(/\s+/).filter(Boolean);
      return { ...page, _tokens: Array.from(new Set(tokens)) };
    });

    function renderSuggestions(matches) {
      suggestionsBox.innerHTML = '';
      currentSelection = -1;
      currentMatches = matches;

      if (!matches.length) {
        suggestionsBox.style.display = 'none';
        return;
      }

      matches.forEach((page, index) => {
        const div = document.createElement('div');
        div.className = 'suggestion';
        div.textContent = page.name;
        div.dataset.index = String(index);

        div.addEventListener('mousedown', event => {
          event.preventDefault();
          dismissMobileKeyboard();
          loadPage(page.path);
        });

        suggestionsBox.appendChild(div);
      });

      suggestionsBox.style.display = 'block';
    }

    function showSuggestions() {
      const input = normalize(searchInputEl.value);

      if (!input) {
        suggestionsBox.style.display = 'none';
        return;
      }

      const matches = pageIndex
        .filter(page => !page.hidden)
        .filter(page => page._tokens.some(token => token.includes(input)));

      renderSuggestions(matches);
    }

    function updateHighlight() {
      const suggestions = Array.from(document.querySelectorAll('.suggestion'));
      suggestions.forEach((el, index) => {
        el.classList.toggle('selected', index === currentSelection);
      });
    }

    function findBestMatch(rawInput) {
      const query = normalize(rawInput);
      if (!query) return null;

      const ranked = pageIndex
        .map(page => {
          let score = 0;
          for (const token of page._tokens) {
            if (token === query) score = Math.max(score, 100);
            else if (token.startsWith(query)) score = Math.max(score, 80);
            else if (token.includes(query)) score = Math.max(score, 60);
          }
          return { page, score };
        })
        .filter(item => item.score > 0)
        .sort((a, b) => b.score - a.score);

      return ranked.length ? ranked[0].page : null;
    }

    async function playGlitchThenGo(path) {
      if (navigating) return;
      navigating = true;

      dismissMobileKeyboard();
      document.body.classList.add('is-navigating');
      glitchOverlay.classList.add('active');
      glitchOverlay.setAttribute('aria-hidden', 'false');

      try {
        glitchVideo.currentTime = 0;
        await glitchVideo.play();
      } catch (e) {}

      const url = new URL(path, window.location.href).toString();
      setTimeout(() => window.location.assign(url), GLITCH_NAV_MS);
    }

    function loadPage(path) {
      if (!path || navigating) return;
      dismissMobileKeyboard();

      if (path === 'personal') {
        playGlitchThenGo(path);
        return;
      }

      showLoader();
      const url = new URL(path, window.location.href).toString();
      setTimeout(() => window.location.assign(url), 160);
    }

    window.loadPage = loadPage;

    function handleKey(event) {
      const suggestions = Array.from(document.querySelectorAll('.suggestion'));

      if (event.key === 'ArrowDown') {
        event.preventDefault();
        if (suggestions.length) {
          currentSelection = (currentSelection + 1) % suggestions.length;
          updateHighlight();
        }
        return;
      }

      if (event.key === 'ArrowUp') {
        event.preventDefault();
        if (suggestions.length) {
          currentSelection = (currentSelection - 1 + suggestions.length) % suggestions.length;
          updateHighlight();
        }
        return;
      }

      if (event.key === 'Enter') {
        event.preventDefault();
        dismissMobileKeyboard();

        if (currentSelection >= 0 && currentSelection < currentMatches.length) {
          loadPage(currentMatches[currentSelection].path);
          return;
        }

        const best = findBestMatch(searchInputEl.value);
        if (best) loadPage(best.path);
        return;
      }

      if (event.key === 'Escape') {
        suggestionsBox.style.display = 'none';
      }
    }

    function animateTitle() {
      const titleEl = document.getElementById('animatedTitle');
      const finalText = titleEl.textContent.trim().toUpperCase();
      const glyphs = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789#$%&?';
      let frame = 0;
      const maxFrames = 28;

      const scramble = setInterval(() => {
        titleEl.textContent = finalText
          .split('')
          .map((char, index) => {
            if (char === ' ') return ' ';
            if (frame / 2 > index + 2) return char;
            return glyphs[Math.floor(Math.random() * glyphs.length)];
          })
          .join('');

        frame += 1;
        if (frame > maxFrames) {
          titleEl.textContent = finalText;
          clearInterval(scramble);
        }
      }, 46);
    }

    function updateClock() {
      const now = new Date();
      clockText.textContent = now.toLocaleTimeString([], {
        hour: '2-digit',
        minute: '2-digit',
        second: '2-digit'
      });
    }

    searchInputEl.addEventListener('input', showSuggestions);
    searchInputEl.addEventListener('keydown', handleKey);

    document.addEventListener('mousedown', event => {
      if (!document.querySelector('.search-bar').contains(event.target)) {
        suggestionsBox.style.display = 'none';
      }
    });

    window.addEventListener('pageshow', () => {
      hideLoader();
      document.body.classList.remove('is-navigating');
      glitchOverlay.classList.remove('active');
      glitchOverlay.setAttribute('aria-hidden', 'true');
      try {
        glitchVideo.pause();
        glitchVideo.currentTime = 0;
      } catch (e) {}
      navigating = false;
    });

    if (window.location.pathname.endsWith('/index.html')) {
      const cleanPath = window.location.pathname.replace('/index.html', '/');
      window.history.replaceState(null, '', cleanPath);
    }

    animateTitle();
    updateClock();
    setInterval(updateClock, 1000);
  </script>
</body>
</html>
